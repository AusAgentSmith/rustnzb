# --- Images ---
RUSTNZB_IMAGE=ausagentsmith/rustnzb:latest
SONARR_IMAGE=lscr.io/linuxserver/sonarr:develop

# --- Ports ---
RUSTNZB_PORT=9091
SONARR_PORT=8991

# --- Folder paths ---
RUSTNZB_DOWNLOADS=./data/rustnzb/downloads
SONARR_TV=./data/sonarr/tv

# --- Prowlarr (indexer proxy) ---
PROWLARR_URL=https://prowlarr.example.com
PROWLARR_API_KEY=your-prowlarr-api-key-here

# --- Permissions ---
PUID=1000
PGID=1000
TZ=Australia/Sydney

# --- Series to test ---
SERIES_TVDB=457770
SERIES_SEARCH=rooster

# --- Primary NNTP server ---
NNTP_HOST=news.example.com
NNTP_PORT=563
NNTP_USER=your-username
NNTP_PASS=your-password
NNTP_CONNECTIONS=4

# --- Backup NNTP server (optional) ---
NNTP_BACKUP_HOST=
NNTP_BACKUP_PORT=563
NNTP_BACKUP_USER=
NNTP_BACKUP_PASS=
NNTP_BACKUP_CONNECTIONS=4

# --- Test settings ---
# Timeout in seconds for download completion monitoring
DOWNLOAD_TIMEOUT=1800
